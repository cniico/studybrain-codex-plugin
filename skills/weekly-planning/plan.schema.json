{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cniico/studybrain-codex-plugin/blob/main/skills/weekly-planning/plan.schema.json",
  "title": "StudyBrain structured weekly plan",
  "description": "Fuente de verdad de la planificación. Markdown y CSV son adaptadores derivados de este objeto.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "planningName", "semesterId", "weekStart", "weekEnd", "timezone", "summaryMarkdown", "warnings", "notes", "events"],
  "properties": {
    "version": { "const": "1.0" },
    "planningName": { "type": "string", "minLength": 1, "maxLength": 200 },
    "semesterId": { "type": "string", "minLength": 1, "maxLength": 120, "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$" },
    "weekStart": { "$ref": "#/$defs/date" },
    "weekEnd": { "$ref": "#/$defs/date" },
    "timezone": { "type": "string", "minLength": 1, "maxLength": 100 },
    "weekStartsOn": {
      "type": "string",
      "enum": ["monday", "tuesday", "wednesday", "thursday", "friday", "saturday", "sunday"]
    },
    "summaryMarkdown": { "type": "string", "minLength": 1, "maxLength": 200000 },
    "warnings": { "type": "array", "maxItems": 100, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
    "notes": { "type": "array", "maxItems": 50, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
    "dataGaps": { "type": "array", "maxItems": 100, "items": { "type": "string", "minLength": 1, "maxLength": 1000 } },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxBlockMinutes": { "type": "integer", "minimum": 1, "maximum": 1440 }
      }
    },
    "events": {
      "type": "array",
      "maxItems": 300,
      "items": { "$ref": "#/$defs/event" }
    }
  },
  "$defs": {
    "date": { "type": "string", "format": "date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "time": { "type": "string", "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d$" },
    "courseSlug": { "type": "string", "minLength": 1, "maxLength": 120, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "date", "startTime", "endTime", "courseSlug", "courseName", "type", "title", "description", "priorityReason"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 200, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "date": { "$ref": "#/$defs/date" },
        "startTime": { "$ref": "#/$defs/time" },
        "endTime": { "$ref": "#/$defs/time" },
        "courseSlug": { "$ref": "#/$defs/courseSlug" },
        "courseName": { "type": "string", "minLength": 1, "maxLength": 200 },
        "type": { "type": "string", "minLength": 1, "maxLength": 80 },
        "title": { "type": "string", "minLength": 1, "maxLength": 300 },
        "description": { "type": "string", "maxLength": 2000 },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "priorityReason": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        }
      }
    }
  }
}
